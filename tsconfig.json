{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node20",
    "moduleResolution": "node16",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "dist",
   "types": ["bun", "node"],
    "noEmit": true,
    "allowImportingTsExtensions":true
  },
  "include": ["server.ts", "src/**/*.ts", "tests/**/*.ts"]
}
